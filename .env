# Asili — Defaults (non-secret, committed to repo)
# Copy to .env.local to override locally. .env.local is gitignored.

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4242

# ─── Clearstack spec enforcement ─────────────────────────────────────────────
SPEC_CODE_MAX_LINES=150
SPEC_TEST_MAX_LINES=300
SPEC_DOCS_MAX_LINES=500
SPEC_CODE_EXTENSIONS=.js,.css
SPEC_DOCS_EXTENSIONS=.md
SPEC_IGNORE_DIRS=node_modules,src/vendor,src/deps,.git,.configs,docs/app-spec,dist

# ─── Deploy (Cloudflare R2) ───────────────────────────────────────────────────
# Only needed for `pnpm run deploy-data`. Get credentials from:
# Cloudflare Dashboard → R2 → Manage R2 API Tokens → Create API token
CF_ACCOUNT_ID=
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
