{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "checkJs": true,
    "allowJs": true,
    "noEmit": true,
    "strict": false,
    "skipLibCheck": true,
    "types": ["node"],
    "paths": {
      "hybrids": ["../node_modules/hybrids/types/index.d.ts"],
      "/packages/*": ["../packages/*"]
    }
  },
  "include": ["../src/**/*.js", "../scripts/**/*.js", "../packages/**/*.js"],
  "exclude": ["../node_modules", "../src/vendor", "../src/deps", "../**/*.test.js"]
}
