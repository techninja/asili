{
  "name": "asili-webapp",
  "version": "0.5.0",
  "type": "module",
  "scripts": {
    "dev": "node server.js",
    "build": "node bundle.mjs && mkdir -p dist && cp *.html components dist/",
    "bundle": "node bundle.mjs",
    "deploy": "aws s3 sync dist/ s3://asili-cdn",
    "test": "node tests/run-tests.js",
