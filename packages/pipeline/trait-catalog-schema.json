{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Asili MONDO-Centered Trait Catalog Schema",
  "type": "object",
  "required": ["traits"],
  "properties": {
    "traits": {
      "type": "object",
      "patternProperties": {
        "^(MONDO:[0-9]{7}|EFO_[0-9]{7})$": {
          "$ref": "#/definitions/Trait"
        }
      },
      "additionalProperties": false
    }
  },
  "definitions": {
    "Trait": {
      "type": "object",
      "required": ["title", "mondo_id", "pgs_ids", "expected_variants", "last_updated"],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "mondo_id": {
          "type": "string",
          "pattern": "^(MONDO:[0-9]{7}|EFO_[0-9]{7})$"
        },
        "pgs_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^PGS[0-9]{6}$"
          },
          "uniqueItems": true
        },
        "expected_variants": {
          "type": "integer",
          "minimum": 0
        },
        "estimated_unique_variants": {
          "type": "integer",
          "minimum": 0
        },
        "last_updated": {
          "type": ["string", "null"],
          "format": "date-time"
        }
      },
      "additionalProperties": false
    }
  }
}