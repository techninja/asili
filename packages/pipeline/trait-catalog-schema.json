{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Asili Trait Catalog Schema",
  "type": "object",
  "required": ["traits"],
  "properties": {
    "traits": {
      "type": "object",
      "patternProperties": {
        "^(MONDO:[0-9]{7}|EFO_[0-9]{7}|HP_[0-9]{7}|OBA_VT[0-9]{7}|OBA_[0-9]{7}|PATO_[0-9]{7})$": {
          "$ref": "#/definitions/Trait"
        }
      },
      "additionalProperties": false
    }
  },
  "definitions": {
    "Trait": {
      "type": "object",
      "required": [
        "title",
        "trait_id",
        "pgs_ids",
        "expected_variants",
        "last_updated"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "trait_id": {
          "type": "string",
          "pattern": "^(MONDO:[0-9]{7}|EFO_[0-9]{7}|HP_[0-9]{7}|OBA_VT[0-9]{7}|OBA_[0-9]{7}|PATO_[0-9]{7})$"
        },
        "pgs_ids": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id"],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^PGS[0-9]{6}$"
              },
              "norm_mean": {
                "type": "number"
              },
              "norm_sd": {
                "type": "number",
                "exclusiveMinimum": 0
              },
              "weight_type": {
                "type": "string"
              },
              "method": {
                "type": "string"
              },
              "performance_weight": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "performance_metrics": {
                "type": "object"
              }
            },
            "additionalProperties": false
          },
          "uniqueItems": true
        },
        "expected_variants": {
          "type": "integer",
          "minimum": 0
        },
        "estimated_unique_variants": {
          "type": "integer",
          "minimum": 0
        },
        "last_updated": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "canonical_uri": {
          "type": "string",
          "format": "uri"
        },
        "excluded_pgs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["pgs_id", "reason"],
            "properties": {
              "pgs_id": {
                "type": "string",
                "pattern": "^PGS[0-9]{6}$"
              },
              "reason": {
                "type": "string"
              },
              "method": {
                "type": "string"
              },
              "weight_type": {
                "type": "string"
              }
            }
          }
        }
      },
      "additionalProperties": false
    }
  }
}
