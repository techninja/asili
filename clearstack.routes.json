{
  "/": {
    "title": "Asili — Privacy-first polygenic risk scores",
    "description": "Upload your DNA file and explore polygenic risk scores for 64 traits. Everything runs in your browser — we never see your data.",
    "ogImage": "https://app.asili.dev/og-image.png",
    "ogTemplate": "home"
  },
  "/trait/:slug": {
    "title": "{slug.name}",
    "description": "{slug.description}",
    "image": "{slug.cover_image.url}",
    "ogImage": "https://data.asili.dev/og/trait/{slug.slug}.png",
    "data": "/tmp/trait_manifest.json:traits",
    "ogTemplate": "trait"
  },
  "/gene/:symbol": {
    "title": "{symbol.emoji} {symbol.symbol} — {symbol.name}",
    "description": "{symbol.editorial_description}",
    "ogImage": "https://data.asili.dev/og/gene/{symbol.symbol}.png",
    "data": "src/data/gene_catalog.json:genes",
    "ogTemplate": "gene"
  }
}
